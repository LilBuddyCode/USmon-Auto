# USmon-Auto environment variables
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local. It's in .gitignore.

# ============================================================
# Anthropic API (for prediction)
# NOTE: Claude Max plan does NOT include API credits.
# API access is billed separately. Buy ~$5-10 of credits at
# console.anthropic.com → Settings → Billing.
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use. Sonnet for cost-efficiency on prediction.
# Use Opus only for eval baseline runs (once a week max).
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# Postgres (Neon free tier)
# ============================================================
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.neon.tech/usmon_auto?sslmode=require

# ============================================================
# Telegram Bot API (for alerts + interactive commands)
# Setup: message @BotFather on Telegram, run /newbot TWICE — one
# for staging, one for production. Per ADR-007.
# ============================================================

# STAGING bot — Duran tests here. Aunt never sees this token.
TELEGRAM_BOT_TOKEN_STAGING=1234567890:AAEh-staging-token-here
TELEGRAM_WEBHOOK_SECRET_STAGING=any-random-string-staging

# PRODUCTION bot — aunt's link. Filled in only after staging passes
# the full test plan in ADR-007.
TELEGRAM_BOT_TOKEN_PROD=
TELEGRAM_WEBHOOK_SECRET_PROD=

# Which bot is THIS deployment serving? Set per environment.
# staging deployment → "staging"
# production deployment → "production"
APP_ENV=staging

# Default alert chat_id for staging (your Telegram chat_id).
# Aunt's chat_id is captured at runtime when she taps Start on the
# production bot, stored in the users table, not env var.
DEFAULT_ALERT_CHAT_ID_STAGING=000000000

# ============================================================
# Auth (single shared password for v1 — Clerk removed for simplicity)
# Pick any strong password and share with aunt out-of-band.
# ============================================================
DASHBOARD_PASSWORD=pick-something-strong

# Vercel Cron auth (Day 6 morning push).
# Vercel automatically sends Authorization: Bearer <CRON_SECRET> on cron-triggered
# requests. If unset, the morning-digest endpoint falls back to DASHBOARD_PASSWORD.
# Recommend: set to a different random value than DASHBOARD_PASSWORD.
CRON_SECRET=any-strong-random-string-for-vercel-cron

# ============================================================
# App config
# ============================================================
NEXT_PUBLIC_APP_URL=https://usmon-auto.vercel.app
NODE_ENV=development

# ============================================================
# Feature flags (turn things off without redeploying)
# ============================================================
ENABLE_TELEGRAM_ALERTS=true
ENABLE_SUPPLIER_COMPARISON=true
ENABLE_EXPIRATION_TRACKING=true
ENABLE_EVAL_ON_PUSH=true

# ============================================================
# Stockout-risk alert tiers (days until predicted stockout)
# ============================================================
ALERT_TIER_1_DAYS=1
ALERT_TIER_2_DAYS=3
ALERT_TIER_3_DAYS=7
